---
// Visor ampliado (lightbox) para cualquier imagen con [data-lightbox].
// data-full = URL de la versión grande; data-caption = epígrafe opcional.
---

<div class="lb" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Imagen ampliada">
  <button class="lb-btn lb-close" type="button" aria-label="Cerrar">✕</button>
  <button class="lb-btn lb-nav lb-prev" type="button" aria-label="Anterior">‹</button>
  <figure class="lb-stage">
    <img class="lb-img" alt="" />
    <figcaption class="lb-cap"></figcaption>
  </figure>
  <button class="lb-btn lb-nav lb-next" type="button" aria-label="Siguiente">›</button>
</div>

<style>
  .lb {
    position: fixed; inset: 0; z-index: 100; display: none;
    align-items: center; justify-content: center;
    background: rgba(20, 17, 13, 0.92);
    backdrop-filter: blur(4px);
    padding: 28px;
  }
  .lb.open { display: flex; }
  .lb-stage { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 16px; max-width: 100%; max-height: 100%; }
  .lb-img {
    max-width: min(92vw, 1400px); max-height: 84vh; object-fit: contain;
    border: 2px solid var(--ink); border-radius: 14px; background: var(--cream);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
  }
  .lb-cap {
    background: var(--paper); border: 1.5px solid var(--ink); border-radius: 999px;
    padding: 0.4em 1em; font-size: 0.92rem; font-weight: 600; color: var(--ink);
  }
  .lb-btn {
    position: absolute; z-index: 2; display: grid; place-items: center;
    border: 2px solid var(--cream); background: rgba(0, 0, 0, 0.4); color: var(--cream);
    cursor: pointer; border-radius: 50%; width: 54px; height: 54px; font-size: 1.6rem; line-height: 1;
    transition: background 0.15s ease;
  }
  .lb-btn:hover { background: rgba(0, 0, 0, 0.75); }
  .lb-close { top: 20px; right: 20px; width: 48px; height: 48px; font-size: 1.2rem; }
  .lb-nav { top: 50%; transform: translateY(-50%); }
  .lb-prev { left: 20px; }
  .lb-next { right: 20px; }
  @media (max-width: 620px) {
    .lb { padding: 12px; }
    .lb-nav { bottom: 22px; top: auto; transform: none; }
    .lb-prev { left: 50%; margin-left: -70px; }
    .lb-next { right: 50%; margin-right: -70px; }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  if (lb) {
    const imgEl = lb.querySelector('.lb-img');
    const capEl = lb.querySelector('.lb-cap');
    const els = Array.from(document.querySelectorAll('[data-lightbox]'));
    const items = els.map((el) => ({
      full: el.dataset.full || el.currentSrc || el.src || '',
      cap: el.dataset.caption || el.alt || '',
    }));
    let idx = -1;
    let lastFocus = null;

    const show = (i) => {
      idx = (i + items.length) % items.length;
      const it = items[idx];
      imgEl.src = it.full;
      imgEl.alt = it.cap;
      capEl.textContent = it.cap;
      capEl.style.display = it.cap ? '' : 'none';
    };
    const open = (i) => {
      lastFocus = document.activeElement;
      show(i);
      lb.classList.add('open');
      lb.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      lb.querySelector('.lb-close').focus();
    };
    const close = () => {
      lb.classList.remove('open');
      lb.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      imgEl.removeAttribute('src');
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    };

    document.addEventListener('click', (e) => {
      const t = e.target.closest('[data-lightbox]');
      if (t) { e.preventDefault(); open(els.indexOf(t)); }
    });
    lb.querySelector('.lb-close').addEventListener('click', close);
    lb.querySelector('.lb-prev').addEventListener('click', (e) => { e.stopPropagation(); show(idx - 1); });
    lb.querySelector('.lb-next').addEventListener('click', (e) => { e.stopPropagation(); show(idx + 1); });
    lb.addEventListener('click', (e) => { if (e.target === lb || e.target.classList.contains('lb-stage')) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });

    // swipe en mobile
    let sx = 0;
    lb.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - sx;
      if (Math.abs(dx) > 50) show(idx + (dx < 0 ? 1 : -1));
    }, { passive: true });
  }
</script>
