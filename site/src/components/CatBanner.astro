---
import { Image, getImage } from 'astro:assets';
import catWardrobe from '../assets/cat-wardrobe.jpg';

const catWardrobeFull = (await getImage({ src: catWardrobe, width: 1600, format: 'webp' })).src;
---

<section style="padding-top:18px;">
  <div class="wrap">
    <div class="cat">
      <Image
        src={catWardrobe}
        alt="El gato del depto asomado en un mueble"
        width={560}
        sizes="(max-width:820px) 92vw, 40vw"
        format="webp"
        data-lightbox
        data-full={catWardrobeFull}
        data-caption="Cómoda con mucho espacio de guardado"
      />
      <div class="bd">
        <span class="eyebrow" style="color:var(--terra);">Bonus</span>
        <h2>Viene con buena compañía</h2>
        <p>
          Hasta el gato encontró su lugar entre los cajones. Porque el depto viene
          amoblado y con mucho espacio de guardado para todas tus cosas.
        </p>
      </div>
    </div>
  </div>
</section>
