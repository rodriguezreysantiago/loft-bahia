---
// Generador de Posts para feed (4 piezas 1080x1080). Apiladas a tamaño nativo.
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { contact } from '../../data/site';
import livingWindow from '../../assets/living-window.jpg';
import catStairs2 from '../../assets/cat-stairs2.jpg';
---

<Base title="Loft Bahía · Posts">
  <div class="sheet">
    <!-- 1 · PORTADA -->
    <div class="post">
      <Image class="full" src={livingWindow} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade" style="background:linear-gradient(180deg,rgba(20,17,13,.5),rgba(20,17,13,0) 35%,rgba(20,17,13,.85));"></div>
      <div class="pad">
        <div class="brand" style="color:#fff;"><span class="mk">⌂</span> Loft Bahía</div>
        <div style="margin-top:auto;">
          <span class="pill" style="background:var(--terra);color:#fff;">En alquiler · Bahía Blanca</span>
          <h2 class="h" style="color:#fff;font-size:96px;margin:24px 0 0;">Monoambiente<br>tipo loft</h2>
          <p style="color:#f2e9d8;font-size:36px;font-weight:600;margin:18px 0 0;">Con entrepiso · Amoblado · Listo para entrar</p>
        </div>
      </div>
    </div>

    <!-- 2 · AMENITIES -->
    <div class="post">
      <div class="pad">
        <div class="brand" style="color:var(--ink);"><span class="mk">⌂</span> Loft Bahía</div>
        <span class="pill" style="background:var(--ink);color:var(--cream);align-self:flex-start;margin-top:30px;">Todo incluido</span>
        <h2 class="h" style="font-size:78px;margin:22px 0 16px;color:var(--ink);">Listo para entrar 🔑</h2>
        <div>
          <div class="li"><span class="c">✓</span> Amoblado y equipado</div>
          <div class="li"><span class="c">✓</span> Cerca de la UTN</div>
          <div class="li"><span class="c">✓</span> A 10 cuadras de la UNS</div>
          <div class="li"><span class="c">✓</span> Lavadero común</div>
          <div class="li"><span class="c">✓</span> Mucho espacio de guardado</div>
          <div class="li" style="border-bottom:none;"><span class="c">✓</span> Ideal estudiantes</div>
        </div>
      </div>
    </div>

    <!-- 3 · DETALLE LOFT -->
    <div class="post">
      <Image class="full" src={catStairs2} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade" style="background:linear-gradient(180deg,rgba(20,17,13,.45),rgba(20,17,13,0) 40%,rgba(20,17,13,.8));"></div>
      <div class="pad">
        <div class="brand" style="color:#fff;"><span class="mk" style="background:var(--terra);">⌂</span> Loft Bahía</div>
        <div style="margin-top:auto;">
          <span class="pill" style="background:var(--petrol);color:#fff;">El espacio</span>
          <h2 class="h" style="color:#fff;font-size:88px;margin:24px 0 0;">Entrepiso<br>con onda</h2>
          <p style="color:#f2e9d8;font-size:36px;font-weight:600;margin:18px 0 0;">Escalera de hierro y madera · Doble altura</p>
        </div>
      </div>
    </div>

    <!-- 4 · CONTACTO -->
    <div class="post">
      <div class="full checker" style="--c1:#e2d4b8;--c2:#efe6d3;--sz:90px;"></div>
      <div class="pad" style="align-items:center;text-align:center;justify-content:center;">
        <div class="brand" style="color:var(--ink);position:absolute;top:74px;left:74px;"><span class="mk">⌂</span> Loft Bahía</div>
        <span class="pill" style="background:var(--terra);color:#fff;">¿Te interesa?</span>
        <h2 class="h" style="font-size:104px;margin:26px 0 14px;color:var(--ink);">Escribinos<br>hoy 💬</h2>
        <p style="font-size:38px;font-weight:600;color:var(--ink-soft);margin:0 0 44px;">Coordinamos visita al toque</p>
        <span class="wa-btn">💬 {contact.phoneDisplay}</span>
      </div>
    </div>
  </div>
</Base>

<style>
  .sheet { width: 1080px; margin: 0; }
  .post {
    width: 1080px; height: 1080px; position: relative; overflow: hidden;
    background-color: var(--cream); font-family: "DM Sans", sans-serif; display: block;
  }
  .full { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .shade { position: absolute; inset: 0; }
  .pad { position: absolute; inset: 0; padding: 74px; display: flex; flex-direction: column; }
  .mk { width: 60px; height: 60px; border: 3px solid #fff; border-radius: 15px; background: var(--petrol); display: grid; place-items: center; color: #fff; font-size: 32px; transform: rotate(-6deg); }
  .brand { display: flex; align-items: center; gap: 14px; font-family: "Bricolage Grotesque"; font-weight: 800; font-size: 36px; }
  .pill { display: inline-flex; align-items: center; gap: 12px; font-weight: 700; font-size: 26px; letter-spacing: .1em; text-transform: uppercase; padding: 14px 26px; border-radius: 999px; }
  .h { font-family: "Bricolage Grotesque"; font-weight: 800; letter-spacing: -.02em; line-height: .97; }
  .li { display: flex; align-items: center; gap: 22px; font-size: 40px; font-weight: 600; color: var(--ink); padding: 22px 0; border-bottom: 2px solid rgba(33,30,24,.15); }
  .li .c { width: 56px; height: 56px; flex: none; border-radius: 15px; display: grid; place-items: center; font-size: 30px; color: #fff; border: 3px solid var(--ink); background: var(--petrol); }
  .li:nth-child(even) .c { background: var(--terra); }
  .wa-btn { display: inline-flex; align-items: center; gap: 16px; background: var(--wa); color: #fff; font-family: "Bricolage Grotesque"; font-weight: 800; font-size: 46px; padding: 26px 46px; border-radius: 999px; border: 3px solid var(--ink); box-shadow: 9px 9px 0 var(--ink); }
</style>
