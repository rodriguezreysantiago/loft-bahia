---
// Generador de Carrusel (6 slides 1080x1080). Apilados a tamaño nativo.
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { contact } from '../../data/site';
import catStairs from '../../assets/cat-stairs.jpg';
import loftLiving from '../../assets/loft-living.jpg';
import kitchen from '../../assets/kitchen.jpg';
import bedroom from '../../assets/bedroom.jpg';
import bath from '../../assets/bath.jpg';
---

<Base title="Loft Bahía · Carrusel">
  <div class="sheet">
    <!-- 1 · COVER -->
    <div class="slide">
      <Image class="full" src={catStairs} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade"></div>
      <div class="pageno">1 / 6</div>
      <div class="pad">
        <div class="brand" style="color:#fff;"><span class="mk">⌂</span> Loft Bahía</div>
        <div style="margin-top:auto;">
          <span class="pill" style="background:var(--terra);color:#fff;">Mirá este loft 👀</span>
          <h2 class="h" style="color:#fff;font-size:104px;margin:24px 0 0;">Monoambiente<br>en alquiler</h2>
          <p class="tagline">Bahía Blanca · deslizá →</p>
        </div>
      </div>
    </div>

    <!-- 2 · LIVING -->
    <div class="slide">
      <Image class="full" src={loftLiving} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade"></div>
      <div class="pageno">2 / 6</div>
      <div class="pad"><div style="margin-top:auto;">
        <span class="pill" style="background:var(--petrol);color:#fff;">Living + cocina</span>
        <h2 class="h" style="color:#fff;font-size:80px;margin:22px 0 0;">Luminoso y abierto</h2>
        <p class="tagline">Piso de madera, ventanal y techo con vigas.</p>
      </div></div>
    </div>

    <!-- 3 · KITCHEN -->
    <div class="slide">
      <Image class="full" src={kitchen} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade"></div>
      <div class="pageno">3 / 6</div>
      <div class="pad"><div style="margin-top:auto;">
        <span class="pill" style="background:var(--terra);color:#fff;">Cocina equipada</span>
        <h2 class="h" style="color:#fff;font-size:80px;margin:22px 0 0;">Lista para cocinar</h2>
        <p class="tagline">Mesada de granito, horno, anafe y alacenas.</p>
      </div></div>
    </div>

    <!-- 4 · ENTREPISO -->
    <div class="slide">
      <Image class="full" src={bedroom} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade"></div>
      <div class="pageno">4 / 6</div>
      <div class="pad"><div style="margin-top:auto;">
        <span class="pill" style="background:var(--petrol);color:#fff;">Entrepiso</span>
        <h2 class="h" style="color:#fff;font-size:80px;margin:22px 0 0;">Tu lugar para dormir</h2>
        <p class="tagline">Arriba, con ventana en arco, mucha luz y placares para guardar todo.</p>
      </div></div>
    </div>

    <!-- 5 · BAÑO + PATIO -->
    <div class="slide">
      <Image class="full" src={bath} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade"></div>
      <div class="pageno">5 / 6</div>
      <div class="pad"><div style="margin-top:auto;">
        <span class="pill" style="background:var(--terra);color:#fff;">Baño nuevo</span>
        <h2 class="h" style="color:#fff;font-size:80px;margin:22px 0 0;">Impecable</h2>
        <p class="tagline">Baño a estrenar + patio común con lugar para bicis.</p>
      </div></div>
    </div>

    <!-- 6 · CTA -->
    <div class="slide light checker" style="--c1:#e2d4b8;--c2:#efe6d3;--sz:90px;">
      <div class="pageno">6 / 6</div>
      <div class="pad" style="align-items:center;text-align:center;justify-content:center;">
        <div class="brand" style="color:var(--ink);position:absolute;top:74px;left:74px;"><span class="mk">⌂</span> Loft Bahía</div>
        <span class="pill" style="background:var(--ink);color:var(--cream);">Última →</span>
        <h2 class="h" style="font-size:100px;margin:26px 0 14px;color:var(--ink);">¿Lo querés ver?</h2>
        <p style="font-size:38px;font-weight:600;color:var(--ink-soft);margin:0 0 44px;">Escribinos y coordinamos visita</p>
        <span class="wa-btn">💬 {contact.phoneDisplay}</span>
        <p style="font-size:30px;font-weight:700;color:var(--ink);margin:40px 0 0;letter-spacing:.12em;text-transform:uppercase;">@ Seguinos · WhatsApp · Llamá</p>
      </div>
    </div>
  </div>
</Base>

<style>
  .sheet { width: 1080px; margin: 0; }
  .slide {
    width: 1080px; height: 1080px; position: relative; overflow: hidden;
    background-color: var(--cream); font-family: "DM Sans", sans-serif; display: block;
  }
  .full { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .shade { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,17,13,.5), rgba(20,17,13,0) 38%, rgba(20,17,13,.85)); }
  .pad { position: absolute; inset: 0; padding: 74px; display: flex; flex-direction: column; }
  .pageno { position: absolute; top: 64px; right: 74px; z-index: 6; font-family: "Bricolage Grotesque"; font-weight: 800; font-size: 34px; color: #fff; background: rgba(0,0,0,.3); padding: 6px 22px; border-radius: 999px; }
  .slide.light .pageno { color: var(--ink); background: rgba(33,30,24,.1); }
  .mk { width: 60px; height: 60px; border: 3px solid #fff; border-radius: 15px; background: var(--petrol); display: grid; place-items: center; color: #fff; font-size: 32px; transform: rotate(-6deg); }
  .brand { display: flex; align-items: center; gap: 14px; font-family: "Bricolage Grotesque"; font-weight: 800; font-size: 36px; }
  .pill { display: inline-flex; align-items: center; gap: 12px; font-weight: 700; font-size: 26px; letter-spacing: .1em; text-transform: uppercase; padding: 14px 26px; border-radius: 999px; }
  .h { font-family: "Bricolage Grotesque"; font-weight: 800; letter-spacing: -.02em; line-height: .97; }
  .tagline { color: #f2e9d8; font-size: 38px; font-weight: 600; margin: 16px 0 0; }
  .wa-btn { display: inline-flex; align-items: center; gap: 16px; background: var(--wa); color: #fff; font-family: "Bricolage Grotesque"; font-weight: 800; font-size: 46px; padding: 26px 46px; border-radius: 999px; border: 3px solid var(--ink); box-shadow: 9px 9px 0 var(--ink); }
</style>
