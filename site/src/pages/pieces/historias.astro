---
// Generador de Historias (5 cuadros 1080x1920). Se apilan a tamaño nativo;
// el script scripts/capturar-piezas.mjs recorta cada uno a PNG.
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { contact } from '../../data/site';
import catStairs from '../../assets/cat-stairs.jpg';
import loftLiving from '../../assets/loft-living.jpg';
import courtyardSky from '../../assets/courtyard-sky.jpg';
---

<Base title="Loft Bahía · Historias">
  <div class="sheet">
    <!-- 1 · COVER -->
    <div class="frame">
      <Image class="full-img" src={catStairs} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade"></div>
      <div class="bar"><span class="active"></span><span></span><span></span><span></span><span></span></div>
      <div class="pad">
        <div class="brand"><span class="mk">⌂</span> Loft Bahía</div>
        <div style="margin-top:auto;">
          <span class="pill" style="background:var(--terra);color:#fff;">En alquiler · Bahía Blanca</span>
          <h1 class="h-xl" style="color:#fff;font-size:138px;margin:34px 0 0;">Monoambiente tipo loft</h1>
          <p class="sub" style="color:#f2e9d8;max-width:18ch;">Con entrepiso, amoblado y a pasos de la facu ✦</p>
        </div>
      </div>
      <div class="swipe"><span class="ar">↑</span> Deslizá para ver más</div>
    </div>

    <!-- 2 · CHECKLIST -->
    <div class="frame">
      <div class="bar"><span></span><span class="active"></span><span></span><span></span><span></span></div>
      <div class="pad">
        <div class="brand" style="color:var(--ink);"><span class="mk">⌂</span> Loft Bahía</div>
        <span class="pill" style="background:var(--ink);color:var(--cream);align-self:flex-start;margin-top:50px;">Todo incluido</span>
        <h2 class="h-xl" style="font-size:96px;margin:30px 0 20px;color:var(--ink);">Listo para<br>entrar 🔑</h2>
        <div style="margin-top:12px;">
          <div class="check-li"><span class="ck">✓</span> Amoblado y equipado</div>
          <div class="check-li"><span class="ck">✓</span> Cerca de la UTN</div>
          <div class="check-li"><span class="ck">✓</span> A 10 cuadras de la UNS</div>
          <div class="check-li"><span class="ck">✓</span> Lavadero común</div>
          <div class="check-li"><span class="ck">✓</span> Ideal estudiantes</div>
        </div>
      </div>
    </div>

    <!-- 3 · LOFT -->
    <div class="frame">
      <Image class="full-img" src={loftLiving} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade"></div>
      <div class="bar"><span></span><span></span><span class="active"></span><span></span><span></span></div>
      <div class="pad">
        <div class="brand"><span class="mk">⌂</span> Loft Bahía</div>
        <div style="margin-top:auto;">
          <span class="pill" style="background:var(--petrol);color:#fff;">El espacio</span>
          <h2 class="h-xl" style="color:#fff;font-size:104px;margin:30px 0 0;">Doble altura,<br>el doble de onda</h2>
          <p class="sub" style="color:#f2e9d8;max-width:20ch;">Abajo vivís y cocinás. Arriba, el entrepiso para dormir.</p>
        </div>
      </div>
    </div>

    <!-- 4 · UBICACIÓN -->
    <div class="frame">
      <Image class="full-img" src={courtyardSky} alt="" width={1080} format="webp" loading="eager" />
      <div class="shade" style="background:linear-gradient(180deg, rgba(31,110,126,.85) 0%, rgba(31,110,126,.25) 45%, rgba(20,17,13,.8) 100%);"></div>
      <div class="bar"><span></span><span></span><span></span><span class="active"></span><span></span></div>
      <div class="pad">
        <div class="brand"><span class="mk" style="background:var(--terra);">⌂</span> Loft Bahía</div>
        <div style="margin-top:auto;">
          <span class="pill" style="background:#fff;color:var(--petrol);">Ubicación</span>
          <h2 class="h-xl" style="color:#fff;font-size:110px;margin:30px 0 30px;">Cerca de<br>todo 📍</h2>
          <div style="display:flex;gap:20px;flex-wrap:wrap;">
            <span class="pill ghost">UTN · a pasos</span>
            <span class="pill ghost">UNS · 10 cuadras</span>
            <span class="pill ghost">Centro de Bahía</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 5 · CTA -->
    <div class="frame checker" style="--c1:#e2d4b8;--c2:#efe6d3;--sz:120px;">
      <div class="bar"><span></span><span></span><span></span><span></span><span class="active"></span></div>
      <div class="pad" style="align-items:center;text-align:center;justify-content:center;">
        <div class="brand" style="color:var(--ink);position:absolute;top:96px;left:84px;"><span class="mk">⌂</span> Loft Bahía</div>
        <span class="pill" style="background:var(--terra);color:#fff;">¿Te interesa?</span>
        <h2 class="h-xl" style="font-size:128px;margin:34px 0 18px;color:var(--ink);">Escribinos<br>hoy 💬</h2>
        <p class="sub" style="color:var(--ink-soft);margin:0 0 56px;max-width:18ch;">Coordinamos una visita al toque.</p>
        <span class="wa-btn">💬 {contact.phoneDisplay}</span>
        <p style="font-size:38px;font-weight:700;color:var(--ink);margin:46px 0 0;letter-spacing:.04em;">WhatsApp · Llamá · Visitá</p>
      </div>
    </div>
  </div>
</Base>

<style>
  /* La hoja apila los cuadros sin separación: el capturador recorta de a 1920px. */
  .sheet { width: 1080px; margin: 0; }
  .frame {
    width: 1080px; height: 1920px; position: relative; overflow: hidden;
    /* background-color (no el shorthand) para no pisar el damero de .checker */
    background-color: var(--cream); font-family: "DM Sans", sans-serif; display: block;
  }
  .frame .pad { position: absolute; inset: 0; padding: 96px 84px; display: flex; flex-direction: column; }
  .frame .bar { position: absolute; top: 40px; left: 84px; right: 84px; display: flex; gap: 8px; z-index: 6; }
  .frame .bar span { flex: 1; height: 6px; border-radius: 3px; background: rgba(255,255,255,.45); }
  .frame .bar span.active { background: #fff; }
  .frame .brand { display: flex; align-items: center; gap: 16px; font-family: "Bricolage Grotesque"; font-weight: 800; font-size: 40px; color: #fff; }
  .frame .brand .mk { width: 64px; height: 64px; border: 3px solid #fff; border-radius: 16px; background: var(--petrol); display: grid; place-items: center; font-size: 34px; transform: rotate(-6deg); }
  .pill { display: inline-flex; align-items: center; gap: 14px; font-weight: 700; font-size: 30px; letter-spacing: .12em; text-transform: uppercase; padding: 18px 30px; border-radius: 999px; }
  .pill.ghost { background: rgba(255,255,255,.16); color: #fff; border: 2px solid rgba(255,255,255,.5); }
  .h-xl { font-family: "Bricolage Grotesque"; font-weight: 800; letter-spacing: -.02em; line-height: .97; }
  .sub { font-size: 46px; font-weight: 600; margin: 26px 0 0; line-height: 1.25; }
  .swipe { position: absolute; left: 0; right: 0; bottom: 80px; text-align: center; color: #fff; font-weight: 700; font-size: 34px; display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .swipe .ar { font-size: 46px; }
  .wa-btn { display: inline-flex; align-items: center; gap: 18px; background: var(--wa); color: #fff; font-family: "Bricolage Grotesque"; font-weight: 800; font-size: 44px; padding: 30px 50px; border-radius: 999px; border: 3px solid var(--ink); box-shadow: 10px 10px 0 var(--ink); }
  .full-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .shade { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,17,13,.55) 0%, rgba(20,17,13,0) 32%, rgba(20,17,13,.15) 60%, rgba(20,17,13,.85) 100%); }
  .check-li { display: flex; align-items: center; gap: 26px; font-size: 46px; font-weight: 600; color: var(--ink); padding: 26px 0; border-bottom: 2px solid rgba(33,30,24,.16); }
  .check-li .ck { width: 64px; height: 64px; flex: none; border-radius: 18px; background: var(--petrol); color: #fff; display: grid; place-items: center; font-size: 36px; border: 3px solid var(--ink); }
  .check-li:nth-child(even) .ck { background: var(--terra); }
</style>
